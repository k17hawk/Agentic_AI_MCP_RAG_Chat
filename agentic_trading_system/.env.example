# .env.example
# Environment variables for trading system

# =========================================
# Database Configuration
# =========================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB (optional)
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=trading
MONGODB_USER=
MONGODB_PASSWORD=

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_SECURE=false

# =========================================
# API Keys
# =========================================

# Financial Data
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
FINANCIAL_MODELING_PREP_KEY=your_fmp_key
FRED_API_KEY=your_fred_api_key

# News APIs
NEWS_API_KEY=your_news_api_key
TAVILY_API_KEY=your_tavily_key

# Social Media
TWITTER_BEARER_TOKEN=your_twitter_token
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_secret

# =========================================
# Broker APIs
# =========================================

# Alpaca
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Interactive Brokers (if using)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# =========================================
# Notifications
# =========================================

# Twilio (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_NUM=+14155238886
TWILIO_SMS_NUM=+1234567890
YOUR_WHATSAPP_NUM=+1234567890
YOUR_PHONE_NUM=+1234567890

# Email
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# =========================================
# System Configuration
# =========================================

# Trading Parameters
INITIAL_CAPITAL=100000
MAX_POSITION_SIZE=0.25
RISK_FREE_RATE=0.02

# Your 60-day requirement
MIN_HISTORY_DAYS=60

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=your_secret_key_here

# =========================================
# Monitoring
# =========================================

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin